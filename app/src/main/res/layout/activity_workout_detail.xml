<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Quay lại"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="#88000000"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="42dp"/>

        <ImageView
            android:id="@+id/imgWorkout"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/txtWorkoutName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bench Press"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtMuscle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhóm cơ: Ngực"
                android:textColor="#AAAAAA"
                android:textSize="18sp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/txtSets"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4 Sets"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:layout_marginTop="14dp"/>

            <TextView
                android:id="@+id/txtReps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12 Reps"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/txtGuide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hướng dẫn tập luyện..."
                android:textColor="#CCCCCC"
                android:textSize="16sp"
                android:layout_marginTop="24dp"/>

            <Button
                android:id="@+id/btnStartTimer"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Bắt đầu Timer"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#7C4DFF"
                android:layout_marginTop="30dp"/>

            <Button
                android:id="@+id/btnVideo"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="🎥 Xem video hướng dẫn"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#333333"
                android:layout_marginTop="14dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>