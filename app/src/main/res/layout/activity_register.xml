<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#121212">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tạo tài khoản"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bắt đầu hành trình của bạn ngay hôm nay"
        android:textColor="#AAAAAA"
        android:textSize="16sp"
        android:layout_marginBottom="30dp"/>

    <EditText
        android:id="@+id/edtRegUsername"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Username"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:padding="14dp"
        android:backgroundTint="#7C4DFF"/>

    <EditText
        android:id="@+id/edtRegEmail"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:padding="14dp"
        android:backgroundTint="#7C4DFF"
        android:layout_marginTop="15dp"/>

    <EditText
        android:id="@+id/edtRegPassword"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Password"
        android:inputType="textPassword"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:padding="14dp"
        android:backgroundTint="#7C4DFF"
        android:layout_marginTop="15dp"/>

    <EditText
        android:id="@+id/edtRegConfirmPassword"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Confirm Password"
        android:inputType="textPassword"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:padding="14dp"
        android:backgroundTint="#7C4DFF"
        android:layout_marginTop="15dp"/>

    <Button
        android:id="@+id/btnRegister"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Đăng ký"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#7C4DFF"
        android:layout_marginTop="30dp"/>

    <TextView
        android:id="@+id/txtLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đã có tài khoản? Đăng nhập"
        android:textColor="#7C4DFF"
        android:layout_marginTop="20dp"
        android:textSize="14sp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="30dp">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#444444"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" Hoặc đăng ký bằng "
            android:textColor="#888888"
            android:textSize="12sp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#444444"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="20dp">

        <ImageButton
            android:id="@+id/btnRegGoogle"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_google"
            android:background="@drawable/bg_social_button"
            android:padding="12dp"
            android:layout_marginEnd="20dp"
            android:contentDescription="Google Sign Up"/>

        <ImageButton
            android:id="@+id/btnRegFacebook"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_facebook"
            android:background="@drawable/bg_social_button"
            android:padding="12dp"
            android:contentDescription="Facebook Sign Up"/>

    </LinearLayout>

</LinearLayout>